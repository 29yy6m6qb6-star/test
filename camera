<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>Safari 9 Camera</title>

<style>
body{
  font-family:sans-serif;
  text-align:center;
  padding:20px;
}

video,canvas{
  width:320px;
  border:1px solid #ccc;
  border-radius:10px;
}

button{
  margin-top:10px;
  padding:10px 20px;
  font-size:16px;
}
</style>
</head>

<body>

<h2>Safari 9 Camera</h2>

<video id="video" autoplay></video>
<br>

<button id="switchBtn">カメラ切替</button>
<button id="captureBtn">撮影</button>

<br><br>

<canvas id="canvas"></canvas>

<script>
var video = document.getElementById("video");
var canvas = document.getElementById("canvas");
var ctx = canvas.getContext("2d");

var currentStream = null;

/*
  Safari 9 は enumerateDevices が弱いので
  facingMode を切り替える方式
*/

var useFront = false;

function stopStream() {
  if(currentStream){
    var tracks = currentStream.getTracks();

    for(var i=0;i<tracks.length;i++){
      tracks[i].stop();
    }
  }
}

function startCamera() {

  stopStream();

  var constraints = {
    video: {
      facingMode: useFront ? "user" : "environment"
    },
    audio: false
  };

  // 古いブラウザ対応
  var getMedia =
    navigator.mediaDevices &&
    navigator.mediaDevices.getUserMedia
      ? navigator.mediaDevices.getUserMedia.bind(navigator.mediaDevices)
      : navigator.getUserMedia ||
        navigator.webkitGetUserMedia ||
        navigator.mozGetUserMedia;

  if(!getMedia){
    alert("カメラ非対応ブラウザ");
    return;
  }

  // Promise版
  if(navigator.mediaDevices &&
     navigator.mediaDevices.getUserMedia){

    getMedia(constraints)
      .then(function(stream){

        currentStream = stream;

        try{
          video.srcObject = stream;
        }catch(e){
          video.src = window.URL.createObjectURL(stream);
        }

        video.play();
      })
      .catch(function(err){
        alert("カメラエラー: " + err);
      });

  } else {

    // callback版
    getMedia.call(
      navigator,
      constraints,

      function(stream){

        currentStream = stream;

        try{
          video.srcObject = stream;
        }catch(e){
          video.src = window.URL.createObjectURL(stream);
        }

        video.play();
      },

      function(err){
        alert("カメラエラー: " + err);
      }
    );
  }
}

// カメラ切替
document.getElementById("switchBtn")
.addEventListener("click", function(){

  useFront = !useFront;

  startCamera();
});

// 撮影
document.getElementById("captureBtn")
.addEventListener("click", function(){

  canvas.width = video.videoWidth;
  canvas.height = video.videoHeight;

  ctx.drawImage(video,0,0);

  var image = canvas.toDataURL("image/png");

  console.log(image);
});

// 起動
startCamera();
</script>

</body>
</html>
